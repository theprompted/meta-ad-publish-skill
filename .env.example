# Copy this to .env and fill in your values.
# Never commit .env — it's in .gitignore.

# Required: your Meta Marketing API access token (long string starting with EAC or EAA).
# Generated by creating a System User in Meta Business Suite + an App in
# developers.facebook.com, then pressing Generate Token on the System User.
# A walkthrough: https://theprompted.github.io/matandvics-funnel/meta-api-setup/
META_ACCESS_TOKEN=

# Required: your Meta ad account ID. Find in Ads Manager URL or Business Settings.
# Format: act_1234567890
META_AD_ACCOUNT_ID=

# Required: your Facebook Page ID. Business Settings > Pages.
META_PAGE_ID=

# Optional: your Instagram User ID (the Business Account ID, NOT the page-backed actor ID).
# Look up via:
#   curl -s -G "https://graph.facebook.com/v25.0/<PAGE_ID>" \
#     --data-urlencode "access_token=$META_ACCESS_TOKEN" \
#     --data-urlencode "fields=instagram_business_account"
# Leave blank for Facebook-only.
META_INSTAGRAM_USER_ID=

# Required for new ad-set creation: your Pixel ID. Events Manager.
META_PIXEL_ID=
